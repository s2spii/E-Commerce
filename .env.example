# =============================================================================
#  MAISON LUMA — Environment configuration (EXAMPLE)
# -----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in REAL values for your environment.
#  NEVER commit a populated `.env`. In production, inject these via a secrets
#  manager (Vault, AWS/GCP Secrets Manager, Doppler...) — not a plain file.
# =============================================================================

# ----- Runtime -----
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
# Public URL of the storefront (used for CORS, e-mails, redirects)
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ----- Database (PostgreSQL) -----
POSTGRES_USER=luma
POSTGRES_PASSWORD=change_me_in_real_life
POSTGRES_DB=luma
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL="postgresql://luma:change_me_in_real_life@localhost:5432/luma?schema=public"

# ----- Authentication / JWT -----
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_long_random_value_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_long_random_value
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days (seconds)

# ----- MFA (TOTP) -----
MFA_ISSUER="Maison Luma"

# ----- Security knobs -----
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000
# Argon2 memory cost in KiB (>= 19456 recommended by OWASP)
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
# Cookie signing secret
COOKIE_SECRET=replace_with_long_random_value

# ----- Rate limiting (Redis optional; in-memory fallback if unset) -----
REDIS_URL=

# ----- Payments (Stripe) — test keys only here -----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ----- E-mail (transactional) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="Maison Luma <no-reply@maisonluma.example>"

# ----- Object storage (images / media) — S3-compatible -----
S3_ENDPOINT=
S3_REGION=eu-west-3
S3_BUCKET=luma-media
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ----- Company / tax identity (used for invoicing & e-reporting) -----
COMPANY_LEGAL_NAME="Maison Luma SAS"
COMPANY_VAT_NUMBER=FR00123456789
COMPANY_SIREN=123456789
COMPANY_COUNTRY=FR
# Default home country for tax determination
TAX_HOME_COUNTRY=FR
TAX_PRICES_INCLUDE_TAX=true

# ----- Frontend public env (Next.js) -----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_NAME="Maison Luma"
